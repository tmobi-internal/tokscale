# =============================================================================
# Tokscale Self-Host (HTTP-only, no domain required)
# =============================================================================
# Copy this file to .env and fill in the values before running.

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- GitHub OAuth ---
# Create at: https://github.com/settings/developers
# Homepage URL: http://<EC2_PUBLIC_IP>
# Callback URL: http://<EC2_PUBLIC_IP>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- App ---
# Use EC2 public IP (no trailing slash)
NEXT_PUBLIC_URL=http://<EC2_PUBLIC_IP>

# Random secret (generate with: openssl rand -hex 32)
AUTH_SECRET=
